---
import Brand from './Brand.astro';

interface Props {
  /** Light pages start the header in its white-glass state */
  light?: boolean;
}

const { light = false } = Astro.props;

const links = [
  { href: '/services', label: 'Services' },
  { href: '/services/ai-odoo', label: 'AI + Odoo', match: '/services/ai-odoo' },
  { href: '/industries', label: 'Industries' },
  { href: '/work', label: 'Work' },
  { href: '/insights', label: 'Insights' },
  { href: '/about', label: 'About' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (l: (typeof links)[number]) => {
  if (l.match) return current.startsWith(l.match);
  // "Services" must not light up while on the AI + Odoo flagship page
  if (l.href === '/services') return current.startsWith('/services') && !current.startsWith('/services/ai-odoo');
  return current.startsWith(l.href);
};
---

<header class:list={['hd', { 'hd--light': light }]} id="hd">
  <div class="hd-inner">
    <a href="/" class="brand" aria-label="Dhiren Narola — home">
      <Brand />
    </a>

    <nav class="hd-links" id="hdLinks" aria-label="Main navigation">
      {links.map((l) => (
        <a href={l.href} class:list={[{ active: isActive(l) }]}>{l.label}</a>
      ))}
      <a href="/contact" class="btn btn--primary hd-cta">
        Book a call <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
      </a>
    </nav>

    <button
      class="hd-toggle"
      id="hdToggle"
      aria-expanded="false"
      aria-controls="hdLinks"
      aria-label="Open menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="hd-progress" id="hdProgress" aria-hidden="true"></div>
</header>

<style>
  .hd {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 100;
    height: var(--nav-h);
    transition:
      background var(--t-med) ease,
      box-shadow var(--t-med) ease,
      height var(--t-med) var(--ease-out);
  }

  .hd-inner {
    max-width: var(--c-lg);
    margin-inline: auto;
    padding-inline: var(--gutter);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-5);
  }

  @media (min-width: 1680px) {
    .hd-inner {
      max-width: var(--c-xl);
    }
  }

  /* Wordmark — script "Dhiren." SVG; letters follow currentColor */
  .brand {
    display: flex;
    align-items: center;
    color: var(--td);
    line-height: 1;
    transition: color var(--t-med) ease;
  }

  .hd-links {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.2vw, 1.9rem);
  }

  .hd-links a:not(.hd-cta) {
    font-size: var(--text-sm);
    font-weight: 530;
    color: var(--td-soft);
    padding: 0.4rem 0;
    position: relative;
    transition: color var(--t-fast) ease;
  }

  .hd-links a:not(.hd-cta):hover {
    color: #fff;
  }

  .hd-links a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    border-radius: 2px;
    background: var(--grad);
  }

  .hd-cta {
    height: 40px;
    padding-inline: 1.1rem;
  }

  /* scrolled → compact white glass */
  .hd.scrolled {
    height: 58px;
    background: rgba(255, 255, 255, 0.94);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    box-shadow:
      0 1px 0 var(--line),
      0 8px 24px -12px rgba(14, 27, 46, 0.14);
  }

  .hd.scrolled .brand {
    color: var(--ink-strong);
  }

  .hd.scrolled .hd-links a:not(.hd-cta) {
    color: var(--ink-soft);
  }

  .hd.scrolled .hd-links a:not(.hd-cta):hover {
    color: var(--accent-strong);
  }

  /* light pages start in white-glass */
  .hd--light {
    background: rgba(255, 255, 255, 0.94);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 var(--line);
  }

  .hd--light .brand {
    color: var(--ink-strong);
  }

  .hd--light .hd-links a:not(.hd-cta) {
    color: var(--ink-soft);
  }

  .hd--light .hd-links a:not(.hd-cta):hover {
    color: var(--accent-strong);
  }

  /* scroll progress hairline */
  .hd-progress {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 0;
    background: var(--grad);
  }

  /* mobile toggle */
  .hd-toggle {
    display: none;
    width: 44px;
    height: 44px;
    background: none;
    border: 0;
    cursor: pointer;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    color: var(--td);
    transition: color var(--t-med) ease;
  }

  .hd.scrolled .hd-toggle,
  .hd--light .hd-toggle {
    color: var(--ink-strong);
  }

  .hd-toggle span {
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transition:
      transform var(--t-med) ease,
      opacity var(--t-med) ease;
  }

  @media (max-width: 900px) {
    .hd-toggle {
      display: flex;
    }

    /* keep brand + toggle above the full-screen panel */
    .hd-inner {
      position: relative;
      z-index: 2;
    }

    /* full-screen overlay menu (covers the header gap in every
       header state — tall, compact/scrolled, and light) */
    .hd-links {
      position: fixed;
      inset: 0;
      z-index: 1;
      flex-direction: column;
      justify-content: center;
      align-items: stretch;
      background: var(--navy-950);
      padding: calc(var(--nav-h) + var(--s-4)) var(--gutter) var(--s-6);
      gap: 0;
      opacity: 0;
      transform: translateY(-12px);
      transition:
        opacity 300ms ease,
        transform 380ms var(--ease-out),
        visibility 0s linear 380ms;
      overflow-y: auto;
      visibility: hidden;
    }

    .hd-links.open {
      opacity: 1;
      transform: none;
      visibility: visible;
      transition:
        opacity 260ms ease,
        transform 380ms var(--ease-out);
    }

    .hd-links a:not(.hd-cta) {
      color: var(--td) !important;
      font-size: 1.35rem;
      font-weight: 600;
      padding: 0.95rem 0;
      border-bottom: 1px solid var(--navy-line);
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 300ms ease,
        transform 340ms var(--ease-out),
        color var(--t-fast) ease;
    }

    .hd-links.open a:not(.hd-cta) {
      opacity: 1;
      transform: none;
    }

    /* gentle stagger as the menu unfolds */
    .hd-links.open a:nth-child(1) { transition-delay: 60ms; }
    .hd-links.open a:nth-child(2) { transition-delay: 105ms; }
    .hd-links.open a:nth-child(3) { transition-delay: 150ms; }
    .hd-links.open a:nth-child(4) { transition-delay: 195ms; }
    .hd-links.open a:nth-child(5) { transition-delay: 240ms; }
    .hd-links.open a:nth-child(6) { transition-delay: 285ms; }
    .hd-links.open a:nth-child(7) { transition-delay: 330ms; }

    .hd-links a.active::after {
      display: none;
    }

    .hd-links a.active {
      color: var(--accent-ondark) !important;
    }

    .hd-cta {
      margin-top: var(--s-5);
      height: 52px;
      opacity: 0;
      transform: translateY(10px);
    }

    .hd-links.open .hd-cta {
      opacity: 1;
      transform: none;
    }

    /* menu open → header sits on the navy panel, so brand + X go white
       regardless of scrolled/light state */
    .hd.menu-open .brand,
    .hd.menu-open .hd-toggle {
      color: var(--td);
    }

    .hd.menu-open.scrolled,
    .hd.menu-open.hd--light {
      background: transparent;
      box-shadow: none;
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
    }

    .hd-toggle[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .hd-toggle[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
    }

    .hd-toggle[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hd,
    .hd-links,
    .hd-links a,
    .hd-cta,
    .hd-toggle span {
      transition: none !important;
    }
  }
</style>

<style is:global>
  body.nav-open {
    overflow: hidden;
  }
</style>

<script>
  const hd = document.getElementById('hd')!;
  const progress = document.getElementById('hdProgress')!;
  const toggle = document.getElementById('hdToggle')!;
  const links = document.getElementById('hdLinks')!;
  const isLight = hd.classList.contains('hd--light');

  let ticking = false;
  const update = () => {
    ticking = false;
    hd.classList.toggle('scrolled', window.scrollY > (isLight ? 10 : 40));
    const max = document.documentElement.scrollHeight - window.innerHeight;
    progress.style.width = (max > 0 ? (window.scrollY / max) * 100 : 0) + '%';
  };
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    },
    { passive: true }
  );
  update();

  toggle.addEventListener('click', () => {
    const open = links.classList.toggle('open');
    hd.classList.toggle('menu-open', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.classList.toggle('nav-open', open);
  });

  links.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) {
      links.classList.remove('open');
      hd.classList.remove('menu-open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('nav-open');
    }
  });
</script>
