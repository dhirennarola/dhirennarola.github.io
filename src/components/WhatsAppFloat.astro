<style>
  .wa-float {
    position: fixed;
    right: clamp(1rem, 3vw, 1.75rem);
    bottom: clamp(1rem, 3vw, 1.75rem);
    z-index: 90;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: #1faa53;
    color: #fff;
    box-shadow: var(--shadow-lg);
    transition: transform var(--t-fast) var(--ease-out), box-shadow var(--t-fast) ease;
  }

  .wa-float:hover {
    transform: translateY(-2px) scale(1.04);
    color: #fff;
  }

  @media print {
    .wa-float {
      display: none;
    }
  }
</style>
