---
import { site, contact, numbers, availability, whatsappUrl } from '../data/facts';
import Brand from './Brand.astro';

const year = new Date().getFullYear();
---

<footer class="ft on-dark">
  <div class="container">
    <div class="ft-top">
      <div class="ft-brand">
        <a href="/" class="ft-logo" aria-label="Dhiren Narola — home"><Brand /></a>
        <p>
          {site.title}. Odoo 18 certified · {numbers.implementations} implementations
          · {numbers.countries} countries · full ownership from architecture to
          go-live.
        </p>
      </div>

      <nav class="ft-col" aria-label="Explore">
        <h4>Explore</h4>
        <a href="/about">About</a>
        <a href="/work">Work</a>
        <a href="/industries">Industries</a>
        <a href="/insights">Insights</a>
        <a href="/contact">Contact</a>
      </nav>

      <nav class="ft-col" aria-label="Services">
        <h4>Services</h4>
        <a href="/services/erp-implementation">ERP Implementation</a>
        <a href="/services/erp-rescue">ERP Rescue</a>
        <a href="/services/ai-odoo">AI + Odoo</a>
        <a href="/services/integrations-einvoicing">Integrations &amp; e-Invoicing</a>
        <a href="/services/dedicated-team">Dedicated Team</a>
      </nav>

      <nav class="ft-col" aria-label="Connect">
        <h4>Connect</h4>
        <a href={contact.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a href={contact.github} target="_blank" rel="noopener">GitHub</a>
        <a href={contact.odooApps} target="_blank" rel="noopener">Odoo App Store</a>
        <a href={whatsappUrl()} target="_blank" rel="noopener">WhatsApp</a>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
      </nav>
    </div>

    <div class="ft-bottom">
      <span>© {year} {site.name}. All rights reserved.</span>
      {availability.active && (
        <span class="ft-avail">
          <span class="dot dot--pulse" aria-hidden="true"></span>
          {availability.short}
        </span>
      )}
      <span class="ft-meta"><a href="/privacy">Privacy</a></span>
    </div>
  </div>
</footer>

<style>
  .ft {
    background: var(--navy-950);
    color: var(--td-faint);
    font-size: var(--text-sm);
  }

  .ft-top {
    display: grid;
    gap: var(--s-6);
    padding-block: var(--sec-s);
    border-bottom: 1px solid var(--navy-line);
  }

  @media (min-width: 900px) {
    .ft-top {
      grid-template-columns: 2fr 1fr 1fr 1.3fr;
      gap: var(--s-7);
    }
  }

  .ft-logo {
    display: inline-flex;
    color: var(--td);
    margin-bottom: var(--s-3);
    transition: color var(--t-fast) ease;
  }

  .ft-logo:hover {
    color: #fff;
  }

  .ft-brand p {
    max-width: 36ch;
    line-height: 1.65;
    color: var(--td-faint);
  }

  .ft-col {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .ft-col h4 {
    color: var(--td);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--s-3);
  }

  .ft-col a {
    color: var(--td-faint);
  }

  .ft-col a:hover {
    color: var(--td);
  }

  .ft-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    justify-content: space-between;
    align-items: center;
    padding-block: var(--s-5);
    font-size: var(--text-xs);
  }

  .ft-avail {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #6fd6a5;
    font-weight: 600;
  }

  .ft-meta a {
    color: var(--td-faint);
  }

  .ft-meta a:hover {
    color: var(--td);
  }
</style>
