---
/**
 * Accessible FAQ accordion. Pass `items` and (optionally) render FAQPage
 * schema on the page via faqSchema() from src/data/schema.ts.
 */
interface Props {
  items: { q: string; a: string }[];
}

const { items } = Astro.props;
---

<div class="faq">
  {items.map((item) => (
    <details class="faq-item">
      <summary>
        {item.q}
        <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </summary>
      <p set:html={item.a} />
    </details>
  ))}
</div>

<style>
  .faq {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    max-width: var(--container-narrow);
  }

  .faq-item {
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0;
    overflow: hidden;
  }

  summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    cursor: pointer;
    padding: var(--s-4) var(--s-5);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--ink-strong);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .chev {
    flex-shrink: 0;
    color: var(--ink-faint);
    transition: transform var(--t-med) var(--ease-out);
  }

  details[open] .chev {
    transform: rotate(180deg);
  }

  details p {
    margin: 0;
    padding: 0 var(--s-5) var(--s-5);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }
</style>
