---
/**
 * Accessible FAQ accordion. Pass `items` and (optionally) render FAQPage
 * schema on the page via faqSchema() from src/data/schema.ts.
 * Open/close is height-animated in JS so the page never jumps.
 */
interface Props {
  items: { q: string; a: string }[];
}

const { items } = Astro.props;
---

<div class="faq">
  {items.map((item) => (
    <details class="faq-item">
      <summary>
        {item.q}
        <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </summary>
      <div class="faq-body">
        <p set:html={item.a} />
      </div>
    </details>
  ))}
</div>

<style>
  .faq {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    max-width: var(--container-narrow);
  }

  .faq-item {
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0;
    overflow: hidden;
    transition: border-color var(--t-med) ease;
  }

  summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    cursor: pointer;
    padding: var(--s-4) var(--s-5);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--ink-strong);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .chev {
    flex-shrink: 0;
    color: var(--ink-faint);
    transition: transform var(--t-med) var(--ease-out);
  }

  details[open] .chev {
    transform: rotate(180deg);
  }

  .faq-body {
    overflow: hidden;
  }

  details p {
    margin: 0;
    padding: 0 var(--s-5) var(--s-5);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  details[open] {
    border-color: var(--accent-line);
  }

  @media (prefers-reduced-motion: reduce) {
    .chev {
      transition: none;
    }
  }
</style>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach((item) => {
    const summary = item.querySelector('summary')!;
    const body = item.querySelector<HTMLElement>('.faq-body')!;
    let anim: Animation | null = null;

    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (reduced) {
        item.open = !item.open;
        return;
      }
      anim?.cancel();

      if (item.open) {
        // close: shrink from current height, then remove [open]
        const h = body.offsetHeight;
        anim = body.animate(
          [
            { height: `${h}px`, opacity: 1 },
            { height: '0px', opacity: 0 },
          ],
          { duration: 240, easing: 'ease' }
        );
        anim.onfinish = () => {
          item.open = false;
          anim = null;
        };
      } else {
        // open: set [open] so content has layout, then grow into place
        item.open = true;
        const h = body.offsetHeight;
        anim = body.animate(
          [
            { height: '0px', opacity: 0 },
            { height: `${h}px`, opacity: 1 },
          ],
          { duration: 280, easing: 'cubic-bezier(0.22, 0.7, 0.3, 1)' }
        );
        anim.onfinish = () => {
          anim = null;
        };
      }
    });
  });
</script>
