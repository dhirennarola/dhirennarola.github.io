---
import { contact, whatsappUrl, availability } from '../data/facts';

interface Props {
  title?: string;
  desc?: string;
  whatsappMsg?: string;
}

const {
  title = 'Let’s see if we’re a fit.',
  desc = `Tell me about your project, or book a 30-minute discovery call. I reply within ${contact.responseTime} — and I come prepared with questions about your business, not a sales pitch.`,
  whatsappMsg,
} = Astro.props;
---

<section class="cta-band">
  <div class="container cta-inner reveal">
    {availability.active && (
      <span class="pill pill--ok cta-avail">
        <span class="dot dot--pulse" aria-hidden="true"></span>
        {availability.label}
      </span>
    )}
    <h2>{title}</h2>
    <p>{desc}</p>
    <div class="cta-actions">
      <a href="/contact" class="btn btn--accent btn--lg">
        Book a discovery call <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a
        href={whatsappUrl(whatsappMsg)}
        target="_blank"
        rel="noopener"
        class="btn btn--band btn--lg"
      >
        WhatsApp me
      </a>
    </div>
  </div>
</section>

<style>
  .cta-inner {
    max-width: 640px;
  }

  .cta-avail {
    background: rgba(31, 163, 107, 0.14);
    border-color: rgba(31, 163, 107, 0.35);
    color: #6fd6a5;
    margin-bottom: var(--s-5);
  }

  .btn--band {
    background: transparent;
    color: var(--td);
    border-color: var(--navy-line);
  }

  .btn--band:hover {
    border-color: var(--accent-ondark);
    color: #fff;
  }
</style>
