---
import Base from '../layouts/Base.astro';
import {
  site,
  contact,
  numbers,
  availability,
  career,
  certifications,
  education,
} from '../data/facts';

const competencies = [
  {
    label: 'Technical',
    items:
      'Python · PostgreSQL · JavaScript / OWL · XML · REST APIs · Git · Linux · AWS · GCP · Odoo.sh · Odoo 11.0–19.0',
  },
  {
    label: 'Functional',
    items:
      'Accounting · HR · Payroll · Sales · Purchase · Inventory · Manufacturing · Quality · CRM · Helpdesk · Subscription · Website · Expense · Dashboards · Project · Timesheet',
  },
  {
    label: 'Leadership',
    items:
      'Team Lead (7 Developers) · Requirement Analysis · Architecture & Planning · Talent Acquisition · Client Communication · Agile / Scrum',
  },
  {
    label: 'Languages',
    items: 'English (Professional) · Hindi (Native) · Gujarati (Native)',
  },
];

const services = [
  'ERP Implementation',
  'ERP Rescue',
  'AI + Odoo Automation',
  'Functional Consulting',
  'Custom Module Development',
  'Third-Party Integration',
  'Server Setup & Deployment (AWS / GCP / Odoo.sh / Contabo)',
];

const experience = [
  {
    company: 'Independent',
    badge: 'Odoo Architect & AI Automation Engineer',
    roles: [
      {
        title: 'Direct-to-Client Engagements',
        period: 'Jul 2026 – Present',
        bullets: [
          `Currently architecting and delivering an end-to-end Odoo ERP platform for <strong>${career.currentEngagement.client}</strong>, a ${career.currentEngagement.location} telecommunications group, under a long-term build contract`,
          'Direct-to-client Odoo implementation, ERP rescue, and AI-automation consulting across the GCC, Europe, and Asia-Pacific — full ownership from discovery to post-go-live support',
        ],
      },
    ],
  },
  {
    company: 'Synodica Solutions Pvt. Ltd., Surat',
    badge: 'Odoo Silver Partner',
    roles: [
      {
        title: 'Development Team Lead',
        period: 'Sep 2024 – Jul 2026',
        bullets: [
          'Led 7 developers across 4 concurrent projects; driving architecture decisions, resource allocation, and delivery timelines',
          'Led talent acquisition — conducting technical interviews and finalizing hires for the development team',
          'Spearheaded client strategy: requirement analysis, gap assessment, solution design, and go-live planning',
          'Increased team productivity by <strong>30%</strong> by introducing AI-driven development workflows and mentoring developers',
          'Reduced project delivery delays by <strong>25%</strong> through structured &amp; improved deployment processes, and streamlined workflows',
        ],
      },
      {
        title: 'Senior Software Engineer',
        note: '(concurrent with Team Lead role)',
        period: 'Mar 2024 – Jul 2026',
        bullets: [
          'Delivered <strong>full-cycle ERP projects</strong> spanning HR, Retail, Manufacturing, Facilities, and IT Services — from requirement gathering and client communication to development, server setup, and go-live support',
          'Independently managed client relationships, translating business needs into technical solutions and functional workflows, achieving <strong>20%</strong> improvement in client retention',
          'Improved development speed by <strong>15%</strong> by enforcing coding standards, conducting code reviews, and optimizing workflows',
        ],
      },
      {
        title: 'Software Engineer',
        period: 'Dec 2022 – Feb 2024',
        bullets: [
          'Revamped a <strong>10,000+ line legacy module</strong>, improving system performance by <strong>30%</strong> and reducing technical debt',
          'Delivered <strong>4 projects</strong>, increasing client satisfaction by <strong>20%</strong> by reducing turnaround time and minimizing rework',
        ],
      },
      {
        title: 'Junior Software Engineer',
        period: 'Sep 2021 – Nov 2022',
        bullets: [
          'Customized and maintained Odoo applications including module design, troubleshooting, and testing',
          'Applied coding standards and contributed to feature development within Agile teams',
        ],
      },
    ],
  },
];

const projects = [
  {
    title: 'Premium Car Servicing & Spare Parts Reseller — KSA',
    bullets: [
      'Architected end-to-end HR, Payroll, Accounting &amp; Sales ecosystem for <strong>300+ employees</strong> across multi-company, multi-branch setup — reducing manual work by <strong>60%</strong>',
      'Streamlined overtime &amp; violation management with full labor law compliance; built employee self-service portal, shift management with approvals, and end-of-service module per local regulations',
      'Integrated WooCommerce (<strong>1,000+ orders/month</strong>), ZATCA e-invoicing (<strong>1,500+ invoices/month</strong>), and a WhatsApp helpdesk bot — cutting ticket response time by <strong>40%</strong> while migrating the client&rsquo;s full accounting process to Odoo',
    ],
    modules:
      'Accounting, Payroll, HR, Attendance, Sales, Purchase, Helpdesk, CRM, Appraisals, Inventory, Expense, Timeoff, Portal',
  },
  {
    title: 'Pharma & Medical Equipment Manufacturer',
    bullets: [
      'Orchestrated full manufacturing workflow — raw materials to finished goods — with strict regulatory compliance for <strong>225 employees</strong>, cutting production tracking errors by <strong>50%</strong>',
      'Customized Shopfloor module: custom production flows, batch generation, split work orders, unbuild MO logic, and samples workflow; revamped QC process at every production stage',
      'Configured structured sales workflow (Quotation → Proforma → Sale Order → Tax Invoice) across <strong>5+ warehouse locations</strong>, and engineered a Tally XML bridge that consolidated <strong>3 separate systems into 1 unified ERP</strong> with cost-per-employee, per-process, and per-department dashboards',
    ],
    modules:
      'Manufacturing, Quality, Sales, Accounting, Purchase, Inventory, HR, Payroll, Attendance, Dashboards, Maintenance, Repairs',
  },
  {
    title: 'Elevator Maintenance & Subscription Company',
    bullets: [
      'Developed automated maintenance scheduling tied to subscription plans for <strong>35+ technicians</strong> and <strong>70 internal users</strong>, reducing missed service visits by <strong>35%</strong>',
      'Crafted custom WhatsApp flow serving <strong>4,000+ customers</strong> — enabling self-service for subscriptions, visit reports, maintenance requests, and payments, replacing <strong>50%</strong> of the call center team',
      'Connected LanaTime attendance devices and Messagebird contact sync, with SMS fallback notifications ensuring <strong>98% customer notification</strong> rate across subscription, maintenance, and service updates',
    ],
    modules: 'CRM, Subscription, Maintenance, Attendance, Contacts',
  },
  {
    title: 'IT Service Company — Hourly Billing & Subscription Platform',
    bullets: [
      'Designed subscription-based hourly billing system: customers purchase monthly hour packages with automatic allocation to projects and auto-renewal on payment, eliminating <strong>100% of manual billing</strong>',
      'Built full customer portal — track consumed hours, task progress, and purchase extra hours directly from sale orders with real-time project allocation, reducing client queries by <strong>45%</strong>',
      'Set up Backblaze storage integration (replacing default Odoo.sh filestore) and managed Odoo.sh deployment; implemented onboarding with auto-fraud detection, mandatory 2FA, and multi-level purchase approvals',
    ],
    modules: 'Subscription, Project, Timesheet, Sales, Purchase, Website',
  },
];
---

<Base
  title="Résumé — Dhiren Narola, Odoo Architect & AI Automation Engineer"
  description="Consultant profile: Odoo 18 certified architect, 22 implementations across 13 countries, ERP rescue and AI automation specialist."
  path="/profile"
  headerLight
>
  <div class="profile-toolbar">
    <div class="container toolbar-inner">
      <span>Consultant profile — print-ready</span>
      <div class="toolbar-actions">
        <a href="/assets/Dhiren-Narola-Odoo-Architect.pdf" class="btn btn--accent" download>
          Download PDF
        </a>
        <button class="btn btn--secondary" onclick="window.print()">Print</button>
      </div>
    </div>
  </div>

  <section class="sheet-wrap">
    <article class="sheet" id="resume">
      <!-- ===== Header ===== -->
      <header class="r-head">
        <h1>{site.name}</h1>
        <p class="r-headline">
          Odoo Architect &amp; AI Automation Engineer<br />
          Odoo 18 Certified | {numbers.implementations} ERPs Delivered Across {numbers.countries} Countries | Zero Failed Go-Lives
        </p>
        <p class="r-contact">
          Surat, India · Working Globally · {contact.phoneDisplay} ·
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
        </p>
        <p class="r-links">
          <a href={site.url}>dhirennarola.com</a> ·
          <a href={contact.linkedin}>linkedin.com/in/dhirennarola</a> ·
          <a href={contact.github}>github.com/dhirennarola</a>
        </p>
        <span class="r-badge">✦ {availability.label}</span>
      </header>

      <!-- ===== Profile ===== -->
      <section class="r-block">
        <h2>Profile</h2>
        <p>
          <strong>Independent Odoo Architect</strong> &amp; <strong>AI Automation Engineer</strong> |
          <strong>Odoo 18 Certified Functional Consultant</strong> with <strong>4+ years</strong> of
          experience delivering <strong>{numbers.implementations} end-to-end ERP implementations</strong> across
          <strong>{numbers.countries} countries</strong> and zero failed go-lives — from requirement analysis and
          solution architecture to development, deployment, and post-go-live support.
        </p>
        <p>
          Previously led a <strong>7-developer team</strong> at <strong>Synodica Solutions</strong> (Odoo Silver
          Partner), managing multiple concurrent projects while driving client strategy, hiring, and technical
          mentorship. Now working independently — architecting Odoo platforms and AI-driven automation for clients
          across the <strong>GCC, Europe, and Asia-Pacific</strong>. Experienced across <strong>Odoo 11.0–19.0</strong>.
        </p>
        <p>
          I specialize in <strong>complete project ownership</strong> — handling client communication, gap analysis,
          solution design, custom development, integrations, server setup, and user training.
        </p>
      </section>

      <!-- ===== Core Competencies ===== -->
      <section class="r-block">
        <h2>Core Competencies</h2>
        {competencies.map((c) => (
          <p class="r-competency"><span class="r-comp-label">{c.label}</span>{c.items}</p>
        ))}
      </section>

      <!-- ===== Services ===== -->
      <section class="r-block">
        <h2>Services</h2>
        <p class="r-services">
          {services.map((s, i) => (
            <>{i > 0 && <span class="r-sep">·</span>}{s}</>
          ))}
        </p>
      </section>

      <!-- ===== Experience ===== -->
      <section class="r-block">
        <h2>Professional Experience</h2>
        {experience.map((exp) => (
          <div class="r-exp">
            <p class="r-company">{exp.company} <span class="r-partner">— {exp.badge}</span></p>
            {exp.roles.map((role) => (
              <div class="r-role">
                <div class="r-role-head">
                  <span class="r-role-title">
                    {role.title}
                    {role.note && <span class="r-role-note"> {role.note}</span>}
                  </span>
                  <span class="r-role-date">{role.period}</span>
                </div>
                <ul>
                  {role.bullets.map((b) => (<li set:html={b} />))}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </section>

      <!-- ===== Key Projects ===== -->
      <section class="r-block">
        <h2>Key Projects</h2>
        {projects.map((p) => (
          <div class="r-project">
            <p class="r-project-title">{p.title}</p>
            <ul>
              {p.bullets.map((b) => (<li set:html={b} />))}
            </ul>
            <p class="r-modules">Modules: {p.modules}</p>
          </div>
        ))}
      </section>

      <!-- ===== Certifications ===== -->
      <section class="r-block avoid-break">
        <h2>Certifications</h2>
        <ul class="r-certs">
          {certifications.map((cert) => (
            <li><strong>{cert.name}</strong> <span class="r-issuer">— {cert.issuer}</span></li>
          ))}
        </ul>
      </section>

      <!-- ===== Education ===== -->
      <section class="r-block avoid-break">
        <h2>Education</h2>
        <p class="r-edu-main">{education.degree}</p>
        <p class="r-edu-detail">{education.school} · {education.year} · {education.detail}</p>
      </section>
    </article>
  </section>
</Base>

<style>
  .profile-toolbar {
    margin-top: 64px;
    border-bottom: 1px solid var(--line);
    background: var(--bg-raised);
    padding: var(--s-3) 0;
  }

  .toolbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--ink-faint);
  }

  .toolbar-actions {
    display: flex;
    gap: var(--s-3);
  }

  .sheet-wrap {
    padding: var(--s-7) var(--s-4);
    display: flex;
    justify-content: center;
    background: var(--bg-inset);
  }

  .sheet {
    background: #fff;
    width: min(820px, 100%);
    padding: clamp(1.75rem, 4vw, 3rem);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-lg);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--ink);
  }

  /* ===== Header ===== */
  .r-head {
    text-align: center;
    border-bottom: 2.5px solid var(--navy-800);
    padding-bottom: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .r-head h1 {
    font-family: var(--font-display);
    font-size: 1.95rem;
    font-weight: 700;
    color: var(--navy-800);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 0.25rem;
  }

  .r-headline {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-strong);
    margin: 0 0 0.35rem;
    line-height: 1.4;
  }

  .r-contact {
    font-size: 0.78rem;
    color: var(--ink-soft);
    margin: 0 0 0.15rem;
  }

  .r-links {
    font-size: 0.76rem;
    color: var(--ink-soft);
    margin: 0;
  }

  .r-contact a,
  .r-links a {
    color: var(--accent-strong);
  }

  .r-badge {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--ok);
    background: var(--ok-tint);
    padding: 0.15rem 0.85rem;
    border-radius: var(--radius-pill);
    letter-spacing: 0.02em;
  }

  /* ===== Section blocks ===== */
  .r-block {
    margin-top: 0.85rem;
  }

  .sheet h2 {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--navy-800);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1.5px solid var(--accent-line);
    padding-bottom: 0.15rem;
    margin: 0 0 0.4rem;
  }

  .r-block p {
    margin: 0 0 0.3rem;
    color: var(--ink-soft);
  }

  .r-block p:last-child {
    margin-bottom: 0;
  }

  /* ===== Competencies ===== */
  .r-competency {
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .r-comp-label {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--navy-800);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.72rem;
    margin-right: 0.5rem;
  }

  /* ===== Services ===== */
  .r-services {
    font-size: 0.8rem;
    line-height: 1.55;
  }

  .r-sep {
    color: var(--accent-strong);
    font-weight: 700;
    margin: 0 0.4rem;
  }

  /* ===== Experience ===== */
  .r-exp {
    margin-bottom: 0.3rem;
  }

  .r-company {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--navy-800);
    margin: 0 0 0.1rem;
  }

  .r-partner {
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--ink-faint);
    font-style: italic;
  }

  .r-role {
    margin-top: 0.35rem;
  }

  .r-role-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .r-role-title {
    font-size: 0.83rem;
    font-weight: 700;
    color: var(--ink);
  }

  .r-role-note {
    font-size: 0.72rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink-faint);
  }

  .r-role-date {
    font-size: 0.74rem;
    color: var(--ink-faint);
    font-style: italic;
    white-space: nowrap;
  }

  .r-role ul,
  .r-project ul {
    margin: 0.15rem 0 0;
    padding-left: 1.05rem;
  }

  .r-role li,
  .r-project li {
    margin-bottom: 0.15rem;
    color: var(--ink-soft);
  }

  .r-role li strong,
  .r-project li strong {
    color: var(--ink-strong);
  }

  /* ===== Projects ===== */
  .r-project {
    margin-bottom: 0.55rem;
    page-break-inside: avoid;
  }

  .r-project-title {
    font-size: 0.83rem;
    font-weight: 700;
    color: var(--accent-strong);
    margin: 0 0 0.1rem;
  }

  .r-modules {
    font-size: 0.72rem;
    color: var(--ink-faint);
    font-style: italic;
    margin: 0.15rem 0 0;
    padding-left: 1.05rem;
  }

  /* ===== Certifications & Education ===== */
  .r-certs {
    margin: 0;
    padding-left: 1.05rem;
  }

  .r-certs li {
    margin-bottom: 0.15rem;
    color: var(--ink-soft);
  }

  .r-issuer {
    color: var(--ink-faint);
  }

  .r-edu-main {
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 0.05rem;
  }

  .r-edu-detail {
    font-size: 0.78rem;
    color: var(--ink-faint);
  }

  .avoid-break {
    page-break-inside: avoid;
  }

  /* ===== Print / PDF ===== */
  @media print {
    .profile-toolbar {
      display: none;
    }

    .sheet-wrap {
      padding: 0;
      background: #fff;
    }

    .sheet {
      width: 100%;
      border: 0;
      box-shadow: none;
      border-radius: 0;
      padding: 0;
      font-size: 8.9pt;
      line-height: 1.32;
      color: #1a1a1a;
    }

    .r-block p,
    .r-role li,
    .r-project li,
    .r-certs li {
      color: #333;
    }

    .r-block {
      margin-top: 0.55rem;
    }

    .sheet h2 {
      margin-bottom: 0.3rem;
    }

    .r-role {
      margin-top: 0.28rem;
    }

    .r-role li,
    .r-project li {
      margin-bottom: 0.1rem;
    }

    .r-project {
      margin-bottom: 0.4rem;
    }

    .r-badge {
      border: 1px solid var(--ok);
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @page {
      size: A4;
      margin: 9mm 12mm;
    }
  }
</style>
