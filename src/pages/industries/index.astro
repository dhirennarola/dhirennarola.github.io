---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import { breadcrumbs } from '../../data/schema';

const jsonLd = [
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'Industries', path: '/industries' },
  ]),
];
---

<Base
  title="Industries — Odoo ERP by Sector | Dhiren Narola"
  description="Odoo ERP expertise proven in production across automotive & Gulf compliance (ZATCA), manufacturing & pharma, facility management & field service, IT/SaaS/telecom, and retail & trading."
  path="/industries"
  keywords={[
    'Odoo for automotive',
    'Odoo for manufacturing',
    'Odoo for pharma',
    'Odoo for facility management',
    'Odoo for field service',
    'Odoo for retail',
    'Odoo ZATCA Saudi Arabia',
  ]}
  jsonLd={jsonLd}
>
  <header class="hero hero--sub on-dark">
    <div class="container">
      <nav class="crumbs rv-h" data-h="1" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span> <span>Industries</span>
      </nav>
      <h1 class="rv-h hub-h1" data-h="2">Industry expertise, proven in production.</h1>
      <p class="lede rv-h" data-h="3">
        Every industry has its own compliance rules, workflows, and failure modes.
        These are the ones I've learned by shipping — not in theory.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="cards cards--3" data-stagger>
        <a href="/industries/automotive-ksa" class="card card--hover">
          <div class="ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9L16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg></div>
          <h3>Automotive &amp; Gulf compliance</h3>
          <p class="clamp3 grow">Multi-branch servicing &amp; parts retail, Saudi payroll (GOSI, EOS), ZATCA Phase 2 at production scale.</p>
          <span class="proof-note">Proof: 300+ employee group, KSA</span>
          <span class="link-arr">Industry page <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></span>
        </a>
        <a href="/industries/manufacturing" class="card card--hover">
          <div class="ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg></div>
          <h3>Manufacturing &amp; Pharma</h3>
          <p class="clamp3 grow">MRP, stage-gate quality, batch traceability, capacity-based multi-warehouse inventory.</p>
          <span class="proof-note">Proof: 225-employee producer, 3→1 systems</span>
          <span class="link-arr">Industry page <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></span>
        </a>
        <a href="/industries/facility-management" class="card card--hover">
          <div class="ic ic--teal" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M12 6h.01M12 10h.01M12 14h.01M16 10h.01M16 14h.01M8 10h.01M8 14h.01"/></svg></div>
          <h3>Facility &amp; Field Service</h3>
          <p class="clamp3 grow">Subscription-driven scheduling, technician tracking, WhatsApp self-service at 4,000+ customer scale.</p>
          <span class="proof-note">Proof: 50% call-center load replaced</span>
          <span class="link-arr">Industry page <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></span>
        </a>
        <a href="/work/it-services-billing" class="card card--hover">
          <div class="ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>IT · SaaS · Telecom</h3>
          <p class="clamp3 grow">Usage &amp; subscription billing, customer portals, security hardening — plus a full telecom ERP in build.</p>
          <span class="proof-note">Proof: 100% manual billing eliminated (US)</span>
          <span class="link-arr">Case study <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></span>
        </a>
        <a href="/work/jewellery-sales-tags" class="card card--hover">
          <div class="ic ic--teal" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M2 9h20"/></svg></div>
          <h3>Retail &amp; Trading</h3>
          <p class="clamp3 grow">POS, e-commerce sync, attribute-rich catalogues (jewellery on Odoo 19), Gulf distribution.</p>
          <span class="proof-note">Proof: Odoo 19 retail build, live</span>
          <span class="link-arr">Case study <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></span>
        </a>
        <div class="card other-card">
          <h3 class="other-h">Your industry not listed?</h3>
          <p>The discovery process is industry-agnostic — the first call maps your workflows regardless of sector.</p>
          <a href="/contact" class="link-arr">Book a discovery call <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    title="Deep expertise beats generic delivery."
    desc="Tell me your industry and your three biggest operational headaches — I'll tell you exactly what Odoo can and can't fix."
  />
</Base>

<style>
  .hub-h1 {
    font-size: var(--text-3xl);
  }

  .proof-note {
    font-size: var(--text-xs);
    color: var(--ink-faint);
  }

  .other-card {
    justify-content: center;
    background: var(--bg-subtle);
  }

  .other-h {
    font-size: var(--text-lg);
  }

  .other-card p {
    font-size: var(--text-sm);
    color: var(--ink-faint);
    margin: 0;
  }
</style>
