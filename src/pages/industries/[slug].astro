---
import Base from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CtaBand from '../../components/CtaBand.astro';
import Faq from '../../components/Faq.astro';
import { industries } from '../../data/industries';
import { breadcrumbs, faqSchema, serviceSchema } from '../../data/schema';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return industries.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;
const path = `/industries/${industry.slug}`;

const caseStudy = industry.caseStudySlug
  ? (await getCollection('work')).find((w) => w.id === industry.caseStudySlug)
  : undefined;

const others = industries.filter((i) => i.slug !== industry.slug);

const jsonLd = [
  serviceSchema({
    name: `Odoo ERP for ${industry.name}`,
    description: industry.metaDescription,
    path,
  }),
  faqSchema(industry.faqs),
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'Industries', path: '/industries' },
    { name: industry.nav, path },
  ]),
];
---

<Base
  title={industry.metaTitle}
  description={industry.metaDescription}
  path={path}
  jsonLd={jsonLd}
>
  <header class="hero hero--sub on-dark">
    <div class="container">
      <nav class="crumbs rv-h" data-h="1" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span>
        <a href="/industries">Industries</a> <span aria-hidden="true">/</span>
        <span>{industry.nav}</span>
      </nav>
      <span class="eyebrow rv-h" data-h="1">Industry expertise</span>
      <h1 class="rv-h ind-h1" data-h="2">{industry.headline}</h1>
      <p class="lede rv-h" data-h="3">{industry.lede}</p>
      <div class="ind-actions rv-h" data-h="4">
        <a href="/contact" class="btn btn--primary btn--lg">
          Book a discovery call <span class="arr" aria-hidden="true">→</span>
        </a>
      </div>
      <div class="proofbar ind-proof rv-h" data-h="5" aria-label="Results in this industry">
        {industry.proofStats.map((stat) => (
          <div class="stat">
            <div class="stat-num">{stat.value}</div>
            <div class="stat-lbl">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <SectionHeader eyebrow="The reality" title="What usually hurts" />
      <div class="grid grid--3">
        {industry.pains.map((pain, i) => (
          <div class:list={['card', 'reveal', i === 1 && 'reveal-d1', i === 2 && 'reveal-d2']}>
            <h3 class="pain-title">{pain.title}</h3>
            <p class="pain-body">{pain.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--subtle">
    <div class="container cap-grid">
      <div class="reveal">
        <SectionHeader
          eyebrow="What I deliver"
          title={`Odoo, shaped for ${industry.name.toLowerCase()}`}
        />
        <ul class="check-list">
          {industry.capabilities.map((cap) => <li>{cap}</li>)}
        </ul>
      </div>
      {caseStudy && (
        <a href={`/work/${caseStudy.id}`} class="card card--hover ind-cs reveal reveal-d1">
          <span class="cs-link-eyebrow">Delivered in this industry</span>
          <h3>{caseStudy.data.title}</h3>
          <p>{caseStudy.data.summary}</p>
          <span class="pillar-link">Read the case study →</span>
        </a>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader eyebrow="FAQ" title="Asked by businesses like yours" />
      <Faq items={industry.faqs} />
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <p class="other-ind reveal">
        Also serving:
        {others.map((o, i) => (
          <>
            <a href={`/industries/${o.slug}`}>{o.nav}</a>{i < others.length - 1 ? ' · ' : ''}
          </>
        ))}
        — plus trading &amp; distribution, retail / POS, IT &amp; SaaS, telecom, and jewellery.
        <a href="/work">See all work →</a>
      </p>
    </div>
  </section>

  <CtaBand
    title={`Running a ${industry.name.toLowerCase()} business on spreadsheets and hope?`}
    whatsappMsg={industry.whatsappMsg}
  />
</Base>

<style>
  .ind-h1 {
    font-size: var(--text-3xl);
    max-width: 24ch;
  }

  .ind-actions {
    margin-top: var(--s-6);
  }

  .ind-proof {
    max-width: 680px;
    margin-top: var(--s-6);
    padding-top: var(--s-6);
  }

  @media (min-width: 700px) {
    .ind-proof {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pain-title {
    font-size: var(--text-base);
  }

  .pain-body {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
  }

  .cap-grid {
    display: grid;
    gap: var(--s-7);
    align-items: start;
  }

  @media (min-width: 900px) {
    .cap-grid {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .ind-cs {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .cs-link-eyebrow {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-strong);
    font-weight: 650;
  }

  .ind-cs h3 {
    font-size: var(--text-base);
    margin: 0;
  }

  .ind-cs p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
    flex-grow: 1;
  }

  .other-ind {
    font-size: var(--text-sm);
    color: var(--ink-faint);
    max-width: 70ch;
  }
</style>
