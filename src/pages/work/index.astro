---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getCollection } from 'astro:content';
import { breadcrumbs } from '../../data/schema';

const work = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base
  title="Work — Odoo ERP Case Studies & Projects | Dhiren Narola"
  description="Case studies from 22 Odoo implementations across 13 countries: ZATCA-compliant ERP for a 300-employee automotive group, pharma manufacturing consolidation, WhatsApp automation at 4,000-customer scale, and more."
  path="/work"
  keywords={[
    'Odoo case study',
    'Odoo implementation example',
    'Odoo project portfolio',
    'ERP case study',
    'ZATCA Odoo implementation',
  ]}
  jsonLd={[breadcrumbs([{ name: 'Home', path: '/' }, { name: 'Work', path: '/work' }])]}
>
  <header class="hero hero--sub on-dark">
    <div class="container">
      <nav class="crumbs rv-h" data-h="1" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span> <span>Work</span>
      </nav>
      <h1 class="rv-h hub-h1" data-h="2">Selected work, with the numbers left in.</h1>
      <p class="lede rv-h" data-h="3">
        22 implementations across 13 countries — five published as full case
        studies, the rest confidential under NDA. Written for the people who
        sign off on ERP budgets.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="cards" data-stagger>
        {work.map((cs, i) => (
          <a href={`/work/${cs.id}`} class="card card--hover">
            <div class="tag-row">
              <span class="tag">{cs.data.industry}</span>
              <span class="tag">{cs.data.country}</span>
              <span class="tag">{cs.data.odooVersion}</span>
              {i === 0 && <span class="pill pill--accent flag-pill">Flagship</span>}
            </div>
            <h2 class="work-h">{cs.data.title}</h2>
            {cs.data.story ? (
              <div class="story grow">
                <div class="story-row"><b>Problem</b><span set:html={cs.data.story.problem} /></div>
                <div class="story-row"><b>Impact</b><span set:html={cs.data.story.impact} /></div>
              </div>
            ) : (
              <p class="work-sum grow">{cs.data.summary}</p>
            )}
            <span class="link-arr">Read the case study <span class="arr" aria-hidden="true"><svg class="i-arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></span>
          </a>
        ))}
        <div class="card nda-card">
          <h3 class="nda-h">+ 17 more under NDA</h3>
          <p>
            US and European enterprise engagements, Gulf implementations, and the
            ongoing New Zealand telecom ERP. References available privately on
            request.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Have a project like one of these?" />
</Base>

<style>
  .hub-h1 {
    font-size: var(--text-3xl);
    max-width: 22ch;
  }

  .flag-pill {
    padding-block: 0.15rem;
  }

  .work-h {
    font-size: var(--text-xl);
    margin: 0;
  }

  .work-sum {
    font-size: var(--text-sm);
    color: var(--ink-faint);
    margin: 0;
  }

  .nda-card {
    justify-content: center;
    background: var(--bg-subtle);
  }

  .nda-h {
    font-size: var(--text-lg);
  }

  .nda-card p {
    font-size: var(--text-sm);
    color: var(--ink-faint);
    margin: 0;
  }
</style>
