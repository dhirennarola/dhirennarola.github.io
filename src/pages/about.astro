---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Testimonial from '../components/Testimonial.astro';
import portrait from '../assets/dhiren-narola.png';
import {
  numbers,
  career,
  certifications,
  education,
  recommendations,
  odooStoreApps,
  contact,
} from '../data/facts';
import { breadcrumbs } from '../data/schema';
---

<Base
  title="About Dhiren Narola — Odoo Architect & AI Automation Engineer"
  description="Odoo 18 certified architect: from junior engineer to leading 7 developers at an Odoo Silver Partner, now delivering 22 ERP implementations' worth of experience directly to clients across 13 countries."
  path="/about"
  ogType="profile"
  headerLight
  keywords={[
    'who is Dhiren Narola',
    'Dhiren Narola Odoo',
    'Odoo certified consultant',
    'Odoo Silver Partner team lead',
    'Chatter Panel Control',
    'Chatter Access Control',
    'POS Product Quick Favourites',
  ]}
  jsonLd={[breadcrumbs([{ name: 'Home', path: '/' }, { name: 'About', path: '/about' }])]}
>
  <!-- ===== Intro: single clear hero ===== -->
  <section class="section section--l about-hero">
    <div class="container about-grid">
      <div>
        <span class="eyebrow rv-h" data-h="1">About</span>
        <h1 class="rv-h about-h1" data-h="2">Not just code.<br />Business outcomes.</h1>
        <p class="lede rv-h" data-h="3">
          Most ERP projects don't fail on code — they fail in the gap between
          what the business needs and what gets built. I've spent my entire
          career closing that gap.
        </p>
        <div class="intro-actions rv-h" data-h="4">
          <a href="/contact" class="btn btn--primary">Work with me <span class="arr" aria-hidden="true">→</span></a>
          <a href="/profile" class="btn btn--outline">View résumé (PDF)</a>
        </div>
      </div>
      <div class="about-visual rv-h" data-h="3">
        <Image
          src={portrait}
          alt="Dhiren Narola — Odoo Architect and AI Automation Engineer"
          width={640}
          densities={[1, 2]}
          loading="eager"
          fetchpriority="high"
          class="about-portrait"
        />
        <div class="float-chip about-chip" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2f7df6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.5 12.9 17 22l-5-3-5 3 1.5-9.1"/></svg>
          <div>Odoo 18 Certified<small>Odoo S.A. · verify on LinkedIn</small></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Dark stat band ===== -->
  <section class="section--dark on-dark statband-sec" aria-label="Career numbers">
    <div class="container">
      <div class="statband" data-stagger>
        <div><div class="stat-num" data-count="22">0</div><div class="stat-lbl">ERPs live</div></div>
        <div><div class="stat-num" data-count="13">0</div><div class="stat-lbl">Countries</div></div>
        <div><div class="stat-num">11–19</div><div class="stat-lbl">Odoo versions</div></div>
        <div><div class="stat-num" data-count="7">0</div><div class="stat-lbl">Developers led</div></div>
        <div><div class="stat-num" data-count="300" data-suffix="+">0</div><div class="stat-lbl">Users, largest ERP</div></div>
        <div><div class="stat-num" data-count="0">0</div><div class="stat-lbl">Failed go-lives</div></div>
      </div>
    </div>
  </section>

  <!-- ===== Story ===== -->
  <section class="section">
    <div class="container container--md">
      <SectionHeader
        eyebrow="The story"
        title="Four years, one ecosystem, compounding depth"
      />
      <div class="story-copy reveal">
        <p>
          I started in Odoo in 2021 — while still completing my engineering
          degree — and never left the ecosystem. That focus is deliberate: ERP
          is a domain where depth compounds. Every implementation teaches you
          patterns the next one needs, and after
          <strong>{numbers.implementationsExact}</strong> across
          <strong>13 countries</strong>, you stop being surprised.
        </p>
        <p>
          Four years at <strong>{career.synodica.company}</strong>, an
          <a href={career.synodica.partnerUrl} target="_blank" rel="noopener">Odoo Silver Partner</a>,
          took me from junior engineer to <strong>Development Team Lead</strong>
          — a team of {numbers.developersLed} developers, four concurrent
          projects, architecture decisions, hiring, and client strategy. I
          introduced AI-driven development workflows that raised the team's
          productivity by roughly 30% — the same acceleration my clients get
          today.
        </p>
        <p>
          Since mid-2026 I work directly with clients as an independent
          architect. Right now that includes
          <strong>{career.currentEngagement.client}</strong>, a
          {career.currentEngagement.location} telecommunications group, where
          I'm architecting and building their ERP platform end-to-end.
        </p>
        <p>
          What I actually sell isn't Odoo modules or AI integrations — it's
          <strong>ownership</strong>. One person who understands your business
          case, architects the system, writes or directs the code, and answers
          for the outcome. That model is why my go-live record is
          {numbers.failedGoLives} failures in {numbers.implementations}
          implementations.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== Timeline ===== -->
  <section class="section section--subtle">
    <div class="container container--md">
      <SectionHeader
        eyebrow="Career"
        title="Four promotions in four years"
        desc="One ecosystem, steadily increasing ownership — verifiable on LinkedIn."
      />
      <div class="tl" data-stagger>
        <div class="tl-item tl-item--now">
          <h3>{career.independent.role}</h3>
          <div class="tl-meta">{career.independent.period} · Remote, global · <span class="tl-current">Current</span></div>
          <p>{career.independent.note} Currently architecting the ERP platform for {career.currentEngagement.client} ({career.currentEngagement.location} telecom group).</p>
        </div>
        <div class="tl-item">
          <h3>Development Team Lead — {career.synodica.company} <span class="pill pill--accent tl-pill">{career.synodica.badge}</span></h3>
          <div class="tl-meta">Sep 2024 – Jul 2026 · {career.synodica.location}</div>
          <p>Led {numbers.developersLed} developers across 4 concurrent ERP projects. ~30% productivity gain via AI-driven workflows; ~25% fewer delivery delays via structured deployment processes.</p>
        </div>
        <div class="tl-item">
          <h3>Software Engineer → Senior Software Engineer</h3>
          <div class="tl-meta">Sep 2021 – Aug 2024 · {career.synodica.company}</div>
          <p>Full-cycle delivery across automotive, pharma, facilities, retail and IT services. Revamped a 10,000+ line legacy module for a ~30% performance gain. Joined while completing {education.degree} ({education.year}, 8.5 CGPA).</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Credentials + products ===== -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Credentials &amp; products"
        title="Certified, published, verifiable"
      />
      <div class="cards cards--3" data-stagger>
        <div class="card card--hover">
          <span class="pill pill--accent self-start">Vendor certification</span>
          <h3>Odoo 18 Functional Certification</h3>
          <p class="clamp3 grow">
            Official certification issued by Odoo S.A. — validated across
            Accounting, Sales, Purchase, Inventory, HR, and Manufacturing.
          </p>
          <a
            href="https://www.linkedin.com/in/dhirennarola/details/certifications/"
            target="_blank"
            rel="noopener"
            class="link-arr"
          >Verify on LinkedIn <span class="arr" aria-hidden="true">→</span></a>
        </div>
        <div class="card card--hover">
          <span class="pill self-start">Professional development</span>
          <h3>AI for Business Decision-Making</h3>
          <p class="clamp3 grow">
            {certifications[1].issuer} ({certifications[1].year}) · plus
            {certifications[2].name} ({certifications[2].issuer}, {certifications[2].year}).
          </p>
        </div>
        <div class="card card--hover">
          <span class="pill pill--grad self-start">Published products</span>
          <h3>3 apps on the Odoo App Store</h3>
          <p class="clamp3 grow">
            {odooStoreApps.map((a) => a.name).join(' · ')} — built and
            maintained for Odoo 19.
          </p>
          <a href={contact.odooApps} target="_blank" rel="noopener" class="link-arr">
            View on the App Store <span class="arr" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Testimonials ===== -->
  <section class="section section--surface" id="testimonials">
    <div class="container">
      <SectionHeader
        eyebrow="Testimonials"
        title="All four, in full view"
        desc="Verified LinkedIn recommendations from clients, my director, and a CTO colleague — every one verifiable at the source."
      />
      <div class="cards" data-stagger>
        {recommendations.map((rec, i) => (
          <Testimonial {...rec} featured={i === 0} />
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-band on-dark">
    <div class="container">
      <h2 class="reveal">The person you just read about answers your inquiry personally.</h2>
      <div class="cta-actions reveal">
        <a href="/contact" class="btn btn--primary btn--lg">
          Book a discovery call <span class="arr" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .self-start {
    align-self: flex-start;
  }

  .about-hero {
    padding-top: calc(var(--nav-h) + var(--sec-m));
  }

  .about-grid {
    display: grid;
    gap: var(--s-7);
    align-items: center;
  }

  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: 1.4fr 1fr;
    }
  }

  .about-h1 {
    font-size: var(--text-3xl);
  }

  .intro-actions {
    display: flex;
    gap: var(--s-3);
    margin-top: var(--s-5);
    flex-wrap: wrap;
  }

  .about-visual {
    justify-self: center;
    position: relative;
  }

  .about-portrait {
    width: min(310px, 70vw);
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-lg);
  }

  .about-chip {
    bottom: -24px;
    right: -24px;
    background: var(--bg-raised);
    border-color: var(--line);
    color: var(--ink-strong);
    box-shadow: var(--shadow-md);
  }

  .about-chip small {
    color: var(--ink-faint);
  }

  @media (max-width: 1023px) {
    .about-chip {
      display: flex;
      right: 0;
    }
  }

  @media (max-width: 640px) {
    .about-chip {
      position: absolute;
      bottom: -18px;
    }
  }

  /* stat band */
  .statband-sec {
    padding-block: var(--sec-s);
  }

  .statband {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
  }

  @media (min-width: 760px) {
    .statband {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  /* story */
  .story-copy {
    max-width: 70ch;
    color: var(--ink-soft);
  }

  /* timeline */
  .tl {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    max-width: 720px;
  }

  .tl::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(var(--accent), var(--line));
    border-radius: 2px;
  }

  .tl-item {
    position: relative;
    padding-left: 2.2rem;
  }

  .tl-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg-raised);
    border: 3px solid var(--line);
  }

  .tl-item--now::before {
    border-color: var(--ok);
    box-shadow: 0 0 0 4px var(--ok-tint);
  }

  .tl-item h3 {
    font-size: var(--text-lg);
    margin-bottom: 2px;
  }

  .tl-pill {
    margin-left: 6px;
    vertical-align: 2px;
  }

  .tl-meta {
    font-size: var(--text-xs);
    color: var(--ink-faint);
    margin-bottom: var(--s-2);
  }

  .tl-current {
    color: var(--ok);
    font-weight: 600;
  }

  .tl-item p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
    max-width: 58ch;
  }
</style>
