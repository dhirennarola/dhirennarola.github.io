---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Testimonial from '../components/Testimonial.astro';
import CtaBand from '../components/CtaBand.astro';
import portrait from '../assets/dhiren-narola.png';
import certificate from '../assets/certificate.jpg';
import {
  numbers,
  career,
  certifications,
  education,
  recommendations,
  odooStoreApps,
  contact,
} from '../data/facts';
import { breadcrumbs } from '../data/schema';
---

<Base
  title="About Dhiren Narola — Odoo Architect & AI Automation Engineer"
  description="Four years, one ecosystem: from junior engineer to leading 7 developers at an Odoo Silver Partner — now delivering 20+ implementations' worth of experience directly to clients worldwide."
  path="/about"
  ogType="profile"
  jsonLd={[breadcrumbs([{ name: 'Home', path: '/' }, { name: 'About', path: '/about' }])]}
>
  <!-- ===== Intro ===== -->
  <section class="subhero">
    <div class="container about-intro">
      <div>
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a> <span aria-hidden="true">/</span> <span>About</span>
        </nav>
        <h1>Not just code.<br />Business outcomes.</h1>
        <p class="lede">
          Most ERP projects don't fail on code — they fail in the gap between
          what the business needs and what gets built. I've spent my entire
          career closing that gap.
        </p>
        <div class="intro-actions">
          <a href="/contact" class="btn btn--accent">Work with me</a>
          <a href="/profile" class="btn btn--secondary">View résumé</a>
        </div>
      </div>
      <div class="about-portrait">
        <Image
          src={portrait}
          alt="Dhiren Narola"
          width={420}
          densities={[1, 2]}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ===== Story ===== -->
  <section class="section section--tight">
    <div class="container story-grid">
      <div class="prose story">
        <p>
          I started in Odoo in 2021 — while still completing my engineering
          degree — and never left the ecosystem. That focus is deliberate.
          ERP is a domain where depth compounds: every implementation teaches
          you patterns the next one needs, and after
          <strong>{numbers.implementationsExact}</strong> across
          <strong>{numbers.countries} countries</strong>, you stop being
          surprised.
        </p>
        <p>
          Four years at <strong>Synodica Solutions</strong>, an Odoo Silver
          Partner, took me from junior engineer to
          <strong>Development Team Lead</strong> — running a team of
          {numbers.developersLed} developers across four concurrent projects,
          owning architecture decisions, hiring, and client strategy. I
          introduced AI-driven development workflows that raised the team's
          productivity by roughly 30% — the same delivery acceleration my
          clients get today.
        </p>
        <p>
          Since mid-2026 I work directly with clients as an independent
          architect. Right now that includes
          <strong>{career.currentEngagement.client}</strong>, a
          {career.currentEngagement.location} telecommunications group, where
          I'm architecting and building their ERP platform end-to-end.
        </p>
        <p>
          What I actually sell isn't Odoo modules or AI integrations — it's
          <strong>ownership</strong>. One person who understands your business
          case, architects the system, writes or directs the code, and answers
          for the outcome. On projects from focused $2K customizations to
          multi-entity ERP programs, that model is why my go-live record is
          {numbers.failedGoLives} failures in {numbers.implementations}
          implementations.
        </p>
      </div>

      <aside class="story-side">
        <div class="card side-card">
          <h3>At a glance</h3>
          <ul class="side-list">
            <li><strong>{numbers.implementations}</strong> ERPs delivered &amp; live</li>
            <li><strong>{numbers.countries}</strong> countries served</li>
            <li><strong>{numbers.odooVersions}</strong> — every major version</li>
            <li><strong>{numbers.developersLed} developers</strong> led at a Silver Partner</li>
            <li><strong>{numbers.largestDeployment}</strong></li>
            <li><strong>{numbers.failedGoLives} failed go-lives</strong></li>
          </ul>
        </div>
        <div class="card side-card">
          <h3>Education</h3>
          <p class="side-edu">
            <strong>{education.degree}</strong><br />
            {education.school} · {education.year}<br />
            <span class="side-note">{education.detail}</span>
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- ===== Career timeline ===== -->
  <section class="section section--subtle">
    <div class="container">
      <SectionHeader
        eyebrow="Career"
        title="Four promotions in four years"
        desc="One ecosystem, steadily increasing ownership — verifiable on LinkedIn."
      />
      <div class="timeline">
        <div class="tl-item tl-item--now reveal">
          <div class="tl-marker" aria-hidden="true"></div>
          <div class="tl-body card">
            <div class="tl-head">
              <h3>{career.independent.role}</h3>
              <span class="pill pill--ok">Current</span>
            </div>
            <p class="tl-period">{career.independent.period} · Remote, global</p>
            <p>{career.independent.note} {career.currentEngagement.summary}</p>
          </div>
        </div>

        <div class="tl-company reveal">
          <h4>{career.synodica.company} — {career.synodica.location}</h4>
          <a href={career.synodica.partnerUrl} target="_blank" rel="noopener" class="pill pill--accent">
            {career.synodica.badge} ↗
          </a>
          <span class="tl-period">{career.synodica.period}</span>
        </div>

        {career.synodica.roles.map((role) => (
          <div class="tl-item reveal">
            <div class="tl-marker tl-marker--past" aria-hidden="true"></div>
            <div class="tl-body card">
              <div class="tl-head">
                <h3>{role.title}</h3>
              </div>
              <p class="tl-period">{role.period}</p>
              <ul>
                {role.highlights.map((h) => <li>{h}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Certifications ===== -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Credentials"
        title="Certified — and verifiable"
        desc="Vendor certification from Odoo S.A. itself, separated honestly from professional development."
      />
      <div class="cert-grid">
        <div class="card cert-main reveal">
          <div class="cert-head">
            <span class="pill pill--accent">Vendor certification</span>
            <h3>Odoo 18 Functional Certification</h3>
            <p>
              Official certification issued by Odoo S.A., validating functional
              expertise across the core business modules — Accounting, Sales,
              Purchase, Inventory, HR, and Manufacturing.
            </p>
            <a
              href="https://www.linkedin.com/in/dhirennarola/details/certifications/"
              target="_blank"
              rel="noopener"
              class="verified"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                <polyline points="22 4 12 14.01 9 11.01" />
              </svg>
              Verify on LinkedIn
            </a>
          </div>
          <a href="/assets/certificate.jpg" target="_blank" rel="noopener" class="cert-thumb" aria-label="Open certificate at full size">
            <Image src={certificate} alt="Odoo 18 Functional Certification issued by Odoo S.A. to Dhiren Narola" width={560} />
          </a>
        </div>
        <div class="cert-side reveal reveal-d1">
          <h4 class="cert-side-title">Professional development</h4>
          {certifications
            .filter((c) => c.tier === 'professional')
            .map((c) => (
              <div class="card cert-mini">
                <strong>{c.name}</strong>
                <span>{c.issuer} · {c.year}</span>
              </div>
            ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Odoo Apps ===== -->
  <section class="section section--subtle">
    <div class="container">
      <SectionHeader
        eyebrow="Published products"
        title="Apps on the official Odoo Store"
        desc="Small, sharply-scoped products — published, maintained, and bought by the Odoo community. Product quality you can inspect before hiring me."
      />
      <div class="grid grid--3">
        {odooStoreApps.map((app, i) => (
          <div class:list={['card', 'app-card', 'reveal', i === 1 && 'reveal-d1', i === 2 && 'reveal-d2']}>
            <span class="tag">{app.version}</span>
            <h3>{app.name}</h3>
            <p>{app.desc}</p>
          </div>
        ))}
      </div>
      <div class="center-cta reveal">
        <a href={contact.odooApps} target="_blank" rel="noopener" class="btn btn--secondary">
          View on the Odoo App Store <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== All recommendations ===== -->
  <section class="section" id="recommendations">
    <div class="container">
      <SectionHeader
        eyebrow="Recommendations"
        title="All four, in full view"
        desc="Public LinkedIn recommendations from clients, my director, and a CTO colleague — every one verifiable at the source."
      />
      <div class="grid grid--2">
        {recommendations.map((rec, i) => (
          <Testimonial {...rec} featured={i === 0} class={`reveal ${i % 2 === 1 ? 'reveal-d1' : ''}`} />
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .about-intro {
    display: grid;
    gap: var(--s-7);
    align-items: center;
  }

  @media (min-width: 860px) {
    .about-intro {
      grid-template-columns: 1.4fr 1fr;
    }
  }

  .intro-actions {
    display: flex;
    gap: var(--s-3);
    margin-top: var(--s-5);
  }

  .about-portrait {
    justify-self: center;
  }

  .about-portrait img {
    width: min(300px, 70vw);
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-lg);
  }

  .story-grid {
    display: grid;
    gap: var(--s-7);
  }

  @media (min-width: 900px) {
    .story-grid {
      grid-template-columns: 1.6fr 1fr;
    }
  }

  .story p {
    font-size: var(--text-base);
  }

  .story-side {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .side-card h3 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
    font-weight: 650;
    margin-bottom: var(--s-4);
  }

  .side-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .side-list li {
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--line);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .side-list li:last-child {
    border-bottom: 0;
    margin-bottom: 0;
  }

  .side-edu {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.7;
  }

  .side-note {
    color: var(--ink-faint);
    font-size: var(--text-xs);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    max-width: 780px;
    position: relative;
  }

  .tl-item {
    display: grid;
    grid-template-columns: 20px 1fr;
    gap: var(--s-4);
  }

  .tl-marker {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ok);
    margin-top: 26px;
    justify-self: center;
    box-shadow: 0 0 0 4px var(--ok-tint);
  }

  .tl-marker--past {
    background: var(--line-strong);
    box-shadow: 0 0 0 4px var(--bg-inset);
  }

  .tl-company {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--s-3);
    padding: var(--s-4) 0 var(--s-2) calc(20px + var(--s-4));
  }

  .tl-company h4 {
    margin: 0;
    font-size: var(--text-base);
  }

  .tl-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--s-3);
    justify-content: space-between;
  }

  .tl-head h3 {
    font-size: var(--text-lg);
    margin: 0;
  }

  .tl-period {
    font-size: var(--text-xs);
    color: var(--ink-faint);
    margin: 0.25rem 0 var(--s-3);
  }

  .tl-body ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .tl-body li {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin-bottom: 0.35rem;
  }

  .tl-body p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
  }

  /* Certs */
  .cert-grid {
    display: grid;
    gap: var(--s-5);
  }

  @media (min-width: 900px) {
    .cert-grid {
      grid-template-columns: 1.7fr 1fr;
    }
  }

  .cert-main {
    display: grid;
    gap: var(--s-5);
  }

  @media (min-width: 700px) {
    .cert-main {
      grid-template-columns: 1.1fr 1fr;
      align-items: center;
    }
  }

  .cert-head h3 {
    margin: var(--s-3) 0;
  }

  .cert-head p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .cert-thumb img {
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    transition: transform var(--t-med) var(--ease-out);
  }

  .cert-thumb:hover img {
    transform: scale(1.015);
  }

  .cert-side-title {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
    margin-bottom: var(--s-4);
  }

  .cert-mini {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: var(--s-4) var(--s-5);
    margin-bottom: var(--s-3);
  }

  .cert-mini strong {
    font-size: var(--text-sm);
  }

  .cert-mini span {
    font-size: var(--text-xs);
    color: var(--ink-faint);
  }

  /* Apps */
  .app-card {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .app-card .tag {
    align-self: flex-start;
  }

  .app-card h3 {
    font-size: var(--text-base);
    margin: 0;
  }

  .app-card p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
  }

  .center-cta {
    text-align: center;
    margin-top: var(--s-6);
  }
</style>
