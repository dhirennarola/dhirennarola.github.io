---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Testimonial from '../components/Testimonial.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import portrait from '../assets/dhiren-narola.png';
import {
  availability,
  career,
  recommendations,
  contact,
} from '../data/facts';
import { faqSchema, professionalServiceSchema } from '../data/schema';
import { getCollection } from 'astro:content';

const insights = (await getCollection('insights'))
  .filter((i) => !i.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const topicPill: Record<string, string> = {
  Compliance: 'pill--accent',
  'ERP Rescue': 'pill--rescue',
  'AI & Automation': 'pill--grad',
};

const faqs = [
  {
    q: 'Do you handle the full implementation yourself?',
    a: 'Yes — one accountable lead from requirements to go-live. I architect the solution, build or direct the custom development, run data migration and UAT, and train your team. For larger scopes I bring in vetted developers under my direction, but ownership never fragments.',
  },
  {
    q: 'We already have a failed or stalled Odoo project. Can it be saved?',
    a: 'Usually, yes — and usually more of it is salvageable than the frustrated team expects. I start with a rapid independent assessment (days, not weeks): what works, what doesn’t, and a written recovery plan with a fixed quote before any remediation begins. See <a href="/services/erp-rescue">ERP Rescue</a>.',
  },
  {
    q: 'What does an engagement cost?',
    a: 'Typical engagements start at $2,000 USD. Full implementations are quoted per scope after a discovery call — always as a written, fixed proposal, never open-ended billing. You’ll know the number before we start.',
  },
  {
    q: 'Where does AI fit into an Odoo project?',
    a: 'Where it pays for itself: WhatsApp self-service flows, document-to-record automation, and workflow agents that prepare repetitive work for human approval. I also use AI-driven development workflows internally, which measurably raised my team’s delivery productivity by ~30%. I’ll tell you honestly where AI is not worth your money — see <a href="/services/ai-odoo">AI + Odoo</a>.',
  },
  {
    q: 'You’re in India — how does remote delivery work across time zones?',
    a: 'All 20+ implementations were delivered remotely across 13 countries — North America, GCC, Europe, Africa, and Asia-Pacific. Structured sprints, proactive written updates, and overlap hours matched to your timezone. I reply within 8 business hours, usually much faster.',
  },
];

const jsonLd = [professionalServiceSchema(), faqSchema(faqs)];
---

<Base
  title="Dhiren Narola — Odoo Architect, Developer & AI Automation Engineer"
  description="Odoo 18 certified architect & developer with 20+ ERP implementations across 13 countries. Odoo implementation, ERP rescue, ZATCA e-invoicing compliance, and AI-powered business automation — one accountable expert from architecture to go-live."
  path="/"
  keywords={[
    'Odoo ERP consultant India',
    'Odoo implementation partner',
    'Odoo developer for hire',
    'ERP consultant Saudi Arabia',
    'Odoo AI integration',
    'WhatsApp Odoo automation',
  ]}
  jsonLd={jsonLd}
>
  <!-- ============ HERO (100svh, dark) ============ -->
  <section class="hero hero--vh on-dark">
    <div class="container">
      <div class="hero-grid">
        <div>
          {availability.active && (
            <span class="pill pill--ok rv-h" data-h="1">
              <span class="dot dot--pulse" aria-hidden="true"></span>
              {availability.label}
            </span>
          )}
          <h1 class="rv-h" data-h="2">
            Enterprise ERP,<br />architected right.<br />
            <span class="rotator" aria-label="Made intelligent with AI">
              <span>Made intelligent with AI.</span>
              <span>Rescued when it fails.</span>
              <span>Integrated end-to-end.</span>
              <span>Delivered on 4 continents.</span>
            </span>
          </h1>
          <p class="hero-lede rv-h" data-h="3">
            I design, build, and rescue <strong>Odoo ERPs</strong> — and automate
            the work your business shouldn't be doing by hand. Odoo 18 certified,
            20+ implementations live across 13 countries, full ownership from
            first requirement to go-live.
          </p>
          <div class="hero-ctas rv-h" data-h="4">
            <a href="/contact" class="btn btn--primary btn--lg">
              Book a discovery call <span class="arr" aria-hidden="true">→</span>
            </a>
            <a href="/work" class="btn btn--outline btn--lg">See my work</a>
          </div>
        </div>

        <div class="hero-visual rv-h" data-h="3">
          <div class="portrait">
            <Image
              src={portrait}
              alt="Dhiren Narola — Odoo Architect and AI Automation Engineer, Odoo 18 certified"
              width={640}
              densities={[1, 2]}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="float-chip float-chip--tl" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#5b9bff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.5 12.9 17 22l-5-3-5 3 1.5-9.1"/></svg>
            <div>Odoo 18 Certified<small>Issued by Odoo S.A.</small></div>
          </div>
          <div class="float-chip float-chip--br" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#12b5c9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8L4.3 10.7l5.8 1.9L12 18.4l1.9-5.8 5.8-1.9-5.8-1.9Z"/></svg>
            <div>AI-Accelerated Delivery<small>~30% faster team output</small></div>
          </div>
        </div>
      </div>

      <div class="proofbar rv-h" data-h="5">
        <div><div class="stat-num" data-count="22">0</div><div class="stat-lbl">ERPs delivered &amp; live</div></div>
        <div><div class="stat-num" data-count="13">0</div><div class="stat-lbl">Countries · 4 continents</div></div>
        <div><div class="stat-num" data-count="0">0</div><div class="stat-lbl">Failed go-lives</div></div>
        <div><div class="stat-num">11–19</div><div class="stat-lbl">Odoo versions mastered</div></div>
      </div>
    </div>
  </section>

  <!-- ============ PILLARS ============ -->
  <section class="section section--l" id="pillars">
    <div class="container">
      <SectionHeader
        eyebrow="What I do"
        title="Three ways businesses engage me"
        desc="Starting fresh, recovering from a bad build, or ready to automate — the model is identical: one accountable architect who owns the outcome."
      />
      <div class="cards cards--3" data-stagger>
        <a href="/services/erp-implementation" class="card card--hover">
          <div class="ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg></div>
          <span class="pill pill--accent self-start">Core offer</span>
          <h3>ERP Implementation</h3>
          <p class="clamp3 grow">Full-cycle Odoo delivery — requirements, architecture, custom development, migration, training, go-live. One lead, zero handoff surprises.</p>
          <span class="link-arr">Plan your implementation <span class="arr" aria-hidden="true">→</span></span>
        </a>
        <a href="/services/erp-rescue" class="card card--hover">
          <div class="ic ic--amber" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
          <span class="pill pill--rescue self-start">Urgent</span>
          <h3>ERP Rescue</h3>
          <p class="clamp3 grow">Stalled, broken, or abandoned Odoo project? Rapid independent assessment, honest verdict, and a fixed-quote recovery plan.</p>
          <span class="link-arr">Get an assessment <span class="arr" aria-hidden="true">→</span></span>
        </a>
        <a href="/services/ai-odoo" class="card card--hover">
          <div class="ic ic--teal" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8L4.3 10.7l5.8 1.9L12 18.4l1.9-5.8 5.8-1.9-5.8-1.9Z"/><path d="M5 3v4M3 5h4M19 17v4M17 19h4"/></svg></div>
          <span class="pill pill--grad self-start">Multiplier</span>
          <h3>AI + Odoo</h3>
          <p class="clamp3 grow">WhatsApp self-service at 4,000-customer scale, document intelligence, and workflow agents — AI where it pays for itself, not where it demos well.</p>
          <span class="link-arr">Explore Intelligent ERP <span class="arr" aria-hidden="true">→</span></span>
        </a>
      </div>

      <!-- currently-building strip -->
      <div class="card now-building reveal">
        <span class="dot dot--pulse now-dot" aria-hidden="true"></span>
        <div>
          <div class="now-eyebrow">Currently building</div>
          <p class="now-text">
            End-to-end Odoo ERP platform for
            <strong>{career.currentEngagement.client}</strong>, a
            {career.currentEngagement.location} telecommunications group — under
            a long-term build contract.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FEATURED WORK (storytelling cards) ============ -->
  <section class="section section--subtle" id="work">
    <div class="container">
      <SectionHeader
        eyebrow="Selected work"
        title="Case studies with the numbers left in"
        desc="Client names stay under NDA — the architecture decisions and measured outcomes don't."
      />
      <div class="cards" data-stagger>
        <a href="/work/ksa-automotive-erp" class="card card--hover">
          <div class="tag-row"><span class="tag">Automotive</span><span class="tag">Saudi Arabia</span><span class="tag">Odoo 16</span></div>
          <h3>One ERP for a 300-employee automotive group — ZATCA compliant</h3>
          <div class="story grow">
            <div class="story-row"><b>Problem</b><span>Disconnected spreadsheets, manual Saudi payroll, and a hard ZATCA Phase 2 deadline.</span></div>
            <div class="story-row"><b>Solution</b><span>Single multi-company Odoo platform — payroll engine, WooCommerce + WhatsApp integration, queued e-invoice clearance.</span></div>
            <div class="story-row"><b>Impact</b><span><strong>60% less manual work</strong> · 1,500+ cleared invoices/mo · ~40% faster ticket response.</span></div>
          </div>
          <span class="link-arr">Read the case study <span class="arr" aria-hidden="true">→</span></span>
        </a>
        <a href="/work/pharma-manufacturing-erp" class="card card--hover">
          <div class="tag-row"><span class="tag">Manufacturing</span><span class="tag">India</span><span class="tag">Pharma</span></div>
          <h3>Three systems into one for a 225-employee pharma producer</h3>
          <div class="story grow">
            <div class="story-row"><b>Problem</b><span>Production, accounting, and quality living in three systems that never agreed.</span></div>
            <div class="story-row"><b>Solution</b><span>Unified ERP with stage-gate QC, custom shop floor, and a Tally bridge for a safe finance migration.</span></div>
            <div class="story-row"><b>Impact</b><span><strong>50% fewer tracking errors</strong> · 3→1 systems · cost analytics per process &amp; department.</span></div>
          </div>
          <span class="link-arr">Read the case study <span class="arr" aria-hidden="true">→</span></span>
        </a>
      </div>
      <div class="center-cta reveal">
        <a href="/work" class="btn btn--outline">All case studies <span class="arr" aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ GLOBAL PRESENCE (dark) ============ -->
  <section class="section section--l section--dark on-dark globe-bg">
    <div class="container">
      <div class="globe-grid">
        <div>
          <SectionHeader
            eyebrow="Global delivery"
            title="Four continents.<br />One accountable architect."
            desc="Every implementation delivered remotely — with overlap hours matched to your timezone and written updates you never have to chase."
          />
          <div class="globe-stats" data-stagger>
            <div><div class="stat-num" data-count="13">0</div><div class="stat-lbl">Countries served</div></div>
            <div><div class="stat-num" data-count="4">0</div><div class="stat-lbl">Continents</div></div>
            <div><div class="stat-num">GMT±12</div><div class="stat-lbl">Timezone coverage</div></div>
          </div>
        </div>
        <div class="country-grid" data-stagger>
          <div class="country"><b><span class="pin" style="margin-right:6px" aria-hidden="true"></span>United States</b><span>SaaS billing automation</span></div>
          <div class="country"><b>Saudi Arabia</b><span>ZATCA ERP · 300+ staff</span></div>
          <div class="country"><b>New Zealand</b><span>Telecom ERP (current)</span></div>
          <div class="country"><b>Netherlands</b><span>Finance customization</span></div>
          <div class="country"><b>Germany</b><span>EU delivery</span></div>
          <div class="country"><b>Rwanda</b><span>Field-service automation</span></div>
          <div class="country"><b>UAE</b><span>Gulf implementations</span></div>
          <div class="country"><b>Qatar</b><span>Gulf implementations</span></div>
          <div class="country country--hub"><b>India · HQ</b><span>+ Egypt, Australia, Mexico, Laos</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ INDUSTRY EXPERTISE (tabs) ============ -->
  <section class="section section--l" id="industries">
    <div class="container">
      <SectionHeader
        eyebrow="Industry expertise"
        title="Industries I've shipped ERPs for"
        desc="Each with its own compliance rules, workflows, and failure modes — learned in production, not in theory."
      />

      <div class="tabs" role="tablist" aria-label="Industries">
        <button class="tab" role="tab" aria-selected="true" aria-controls="ind-auto">Automotive &amp; Gulf</button>
        <button class="tab" role="tab" aria-selected="false" aria-controls="ind-mfg">Manufacturing &amp; Pharma</button>
        <button class="tab" role="tab" aria-selected="false" aria-controls="ind-fm">Facility &amp; Field Service</button>
        <button class="tab" role="tab" aria-selected="false" aria-controls="ind-it">IT · SaaS · Telecom</button>
        <button class="tab" role="tab" aria-selected="false" aria-controls="ind-retail">Retail &amp; Trading</button>
      </div>

      <div class="tabpanel active" id="ind-auto" role="tabpanel">
        <div class="cards">
          <div class="card">
            <h3>What usually hurts</h3>
            <ul class="check-list mt-3">
              <li>ZATCA Phase 2 deadlines with real penalties</li>
              <li>Saudi labor-law payroll (GOSI, EOS) done by hand</li>
              <li>Branches that never reconcile at head office</li>
            </ul>
          </div>
          <a href="/work/ksa-automotive-erp" class="card card--hover">
            <span class="eyebrow mb-3">Delivered proof</span>
            <h3>300+ employee automotive group, KSA</h3>
            <p class="clamp3 grow">Multi-company ERP with ZATCA Phase 2 at 1,500+ invoices/month, Saudi payroll engine, WhatsApp service desk, and WooCommerce sync.</p>
            <span class="link-arr">Case study <span class="arr" aria-hidden="true">→</span></span>
          </a>
        </div>
      </div>
      <div class="tabpanel" id="ind-mfg" role="tabpanel">
        <div class="cards">
          <div class="card">
            <h3>What usually hurts</h3>
            <ul class="check-list mt-3">
              <li>Batch traceability living in binders and memory</li>
              <li>Production, accounting &amp; QC in disconnected systems</li>
              <li>No idea what production actually costs</li>
            </ul>
          </div>
          <a href="/work/pharma-manufacturing-erp" class="card card--hover">
            <span class="eyebrow mb-3">Delivered proof</span>
            <h3>225-employee pharma manufacturer, India</h3>
            <p class="clamp3 grow">Full MRP with stage-gate quality control across 5+ warehouses — 50% fewer tracking errors, three systems consolidated into one.</p>
            <span class="link-arr">Case study <span class="arr" aria-hidden="true">→</span></span>
          </a>
        </div>
      </div>
      <div class="tabpanel" id="ind-fm" role="tabpanel">
        <div class="cards">
          <div class="card">
            <h3>What usually hurts</h3>
            <ul class="check-list mt-3">
              <li>Missed maintenance visits breaching subscription SLAs</li>
              <li>Every customer interaction needing a phone call</li>
              <li>Zero real-time view of the field workforce</li>
            </ul>
          </div>
          <a href="/work/elevator-maintenance-automation" class="card card--hover">
            <span class="eyebrow mb-3">Delivered proof</span>
            <h3>Elevator maintenance platform, Rwanda</h3>
            <p class="clamp3 grow">Subscription-driven scheduling for 35+ technicians and WhatsApp self-service for 4,000+ customers — half the call-center load replaced.</p>
            <span class="link-arr">Case study <span class="arr" aria-hidden="true">→</span></span>
          </a>
        </div>
      </div>
      <div class="tabpanel" id="ind-it" role="tabpanel">
        <div class="cards">
          <div class="card">
            <h3>What usually hurts</h3>
            <ul class="check-list mt-3">
              <li>Hour packages tracked in spreadsheets, disputed monthly</li>
              <li>Clients emailing for every status update</li>
              <li>Billing that consumes billable time</li>
            </ul>
          </div>
          <a href="/work/it-services-billing" class="card card--hover">
            <span class="eyebrow mb-3">Delivered proof</span>
            <h3>US IT services billing platform + NZ telecom ERP</h3>
            <p class="clamp3 grow">Self-allocating hour subscriptions with a customer portal (100% of manual billing eliminated) — and a full telecom ERP build now in progress.</p>
            <span class="link-arr">Case study <span class="arr" aria-hidden="true">→</span></span>
          </a>
        </div>
      </div>
      <div class="tabpanel" id="ind-retail" role="tabpanel">
        <div class="cards">
          <div class="card">
            <h3>What usually hurts</h3>
            <ul class="check-list mt-3">
              <li>Catalogues that flatten industry-specific attributes</li>
              <li>POS and back office disagreeing on stock</li>
              <li>E-commerce orders re-keyed by hand</li>
            </ul>
          </div>
          <a href="/work/jewellery-sales-tags" class="card card--hover">
            <span class="eyebrow mb-3">Delivered proof</span>
            <h3>Jewellery retail on Odoo 19 + trading &amp; distribution work</h3>
            <p class="clamp3 grow">Attribute-true product tagging and streamlined retail sales on the newest Odoo release — plus distribution implementations across the Gulf.</p>
            <span class="link-arr">Case study <span class="arr" aria-hidden="true">→</span></span>
          </a>
        </div>
      </div>

      <div class="center-cta reveal">
        <a href="/industries" class="btn btn--outline">Explore all industries <span class="arr" aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section section--surface" id="proof">
    <div class="container">
      <SectionHeader
        align="center"
        eyebrow="Testimonials"
        title="What clients say — with names attached"
        desc="Verified LinkedIn recommendations — real names, real roles, verifiable in one click."
      />
      <div class="cards" data-stagger>
        <Testimonial {...recommendations[0]} featured />
        <Testimonial {...recommendations[1]} />
      </div>
      <div class="center-cta reveal">
        <a href="/about#testimonials" class="link-arr">All four testimonials <span class="arr" aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ PROCESS ============ -->
  <section class="section section--l" id="process">
    <div class="container">
      <SectionHeader
        eyebrow="How I work"
        title="A process built on ownership"
        desc="You always know what's happening, what's next, and who's responsible. (It's me.)"
      />
      <ol class="steps" data-stagger>
        <li>
          <span class="no" aria-hidden="true">01</span>
          <h3>Discovery &amp; architecture</h3>
          <p>Your business first, the system second — requirements, gap analysis, and a signed-off architecture so we build the right thing once.</p>
        </li>
        <li>
          <span class="no" aria-hidden="true">02</span>
          <h3>Sprint-based delivery</h3>
          <p>Structured sprints with written updates and working demos — accelerated by AI-assisted workflows that cut iteration time.</p>
        </li>
        <li>
          <span class="no" aria-hidden="true">03</span>
          <h3>Go-live &amp; handover</h3>
          <p>Migration, UAT, and a calm go-live with documentation and training. No black boxes, no dependency on me by design.</p>
        </li>
        <li>
          <span class="no" aria-hidden="true">04</span>
          <h3>Support that answers</h3>
          <p>SLA-based support from the person who architected your system — replies within {contact.responseTime}.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ============ INSIGHTS ============ -->
  <section class="section section--subtle" id="insights">
    <div class="container">
      <SectionHeader
        eyebrow="Insights"
        title="Field notes, not content marketing"
        desc="What I've learned running ERP and automation projects in production — written for people with real budgets."
      />
      <div class="cards cards--3" data-stagger>
        {insights.map((post) => (
          <a href={`/insights/${post.id}`} class="card card--hover">
            <span class:list={['pill', topicPill[post.data.topic] ?? 'pill--accent', 'self-start']}>{post.data.topic}</span>
            <h3 class="insight-title">{post.data.title}</h3>
            <p class="clamp3 grow">{post.data.description}</p>
            <span class="insight-meta">{post.data.readingTime} read</span>
          </a>
        ))}
      </div>
      <div class="center-cta reveal">
        <a href="/insights" class="btn btn--outline">All insights <span class="arr" aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="section" id="faq">
    <div class="container container--sm">
      <SectionHeader align="center" eyebrow="FAQ" title="Questions buyers actually ask" />
      <Faq items={faqs} />
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .self-start {
    align-self: flex-start;
  }

  .mt-3 {
    margin-top: var(--s-3);
  }

  .mb-3 {
    margin-bottom: var(--s-3);
  }

  .center-cta {
    text-align: center;
    margin-top: var(--s-6);
  }

  /* currently-building strip */
  .now-building {
    margin-top: var(--s-6);
    display: flex;
    gap: var(--s-4);
    align-items: flex-start;
    border-left: 3px solid var(--ok);
  }

  .now-dot {
    margin-top: 9px;
  }

  .now-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ok);
    margin-bottom: 4px;
  }

  .now-text {
    margin: 0;
    font-size: var(--text-sm);
  }

  /* global presence */
  .globe-grid {
    display: grid;
    gap: var(--s-7);
    align-items: center;
  }

  @media (min-width: 960px) {
    .globe-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .globe-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
  }

  /* insights */
  .insight-title {
    font-size: var(--text-lg);
    margin: 0;
  }

  .insight-meta {
    font-size: var(--text-xs);
    color: var(--ink-faint);
  }
