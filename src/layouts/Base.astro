---
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/manrope';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { site, contact, numbers, odooStoreApps } from '../data/facts';

interface Props {
  title: string;
  description: string;
  /** Path beginning with / — used for canonical + OG url */
  path: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  jsonLd?: object[];
  noindex?: boolean;
  /** Utility pages with light backgrounds start the header in its white-glass state */
  headerLight?: boolean;
  /** Extra keywords appended to the site-wide set */
  keywords?: string[];
}

const {
  title,
  description,
  path,
  ogImage = '/og/default.png',
  ogType = 'website',
  jsonLd = [],
  noindex = false,
  headerLight = false,
  keywords = [],
} = Astro.props;

const canonical = new URL(path.endsWith('/') || path.includes('.') ? path : path + '/', site.url).href;
const ogImageAbs = new URL(ogImage, site.url).href;

const baseKeywords = [
  'Dhiren Narola',
  'Odoo Architect',
  'Odoo Developer',
  'Odoo Consultant',
  'Odoo Expert',
  'Odoo ERP Implementation',
  'ERP Rescue',
  'AI Automation Engineer',
  'ZATCA e-invoicing Odoo',
  'Odoo Customization',
  'hire Odoo developer',
  'freelance Odoo consultant',
];
const allKeywords = [...new Set([...baseKeywords, ...keywords])].join(', ');

/** Person schema present on every page — the entity Google associates with "Dhiren Narola". */
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${site.url}/#person`,
  name: site.name,
  alternateName: ['Dhiren', 'Dhiren Narola Odoo'],
  jobTitle: 'Odoo Architect & AI Automation Engineer',
  description:
    'Odoo 18 certified ERP architect and AI automation engineer with 20+ Odoo implementations delivered across 12+ countries. Specialist in Odoo ERP implementation, ERP rescue, ZATCA e-invoicing compliance, and AI-powered business automation.',
  url: site.url,
  image: `${site.url}/assets/dhiren-narola.jpg`,
  email: `mailto:${contact.email}`,
  telephone: contact.phoneDisplay,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Surat',
    addressRegion: 'Gujarat',
    addressCountry: 'IN',
  },
  nationality: { '@type': 'Country', name: 'India' },
  sameAs: [contact.linkedin, contact.github, contact.odooApps],
  knowsLanguage: ['en', 'hi', 'gu'],
  knowsAbout: [
    'Odoo ERP',
    'Odoo Development',
    'Odoo Implementation',
    'Odoo Customization',
    'ERP Architecture',
    'ERP Implementation',
    'ERP Rescue and Recovery',
    'AI Automation',
    'AI Agents',
    'LLM Integration',
    'ZATCA Phase 2 e-invoicing',
    'WhatsApp Business API automation',
    'Business Process Automation',
    'Odoo Manufacturing MRP',
    'Odoo Accounting',
    'Saudi Arabia payroll (GOSI, EOS)',
    'WooCommerce Odoo integration',
    'Python',
    'PostgreSQL',
  ],
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Odoo Architect / Odoo Developer / ERP Consultant',
    occupationalCategory: 'Software Architect',
    skills:
      'Odoo 11–19, ERP implementation, ERP rescue, AI automation, ZATCA e-invoicing, Python, PostgreSQL, WhatsApp Business API, LLM integrations',
  },
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'certification',
    name: 'Odoo 18 Functional Certification',
    recognizedBy: { '@type': 'Organization', name: 'Odoo S.A.' },
  },
  owns: odooStoreApps.map((app) => ({
    '@type': 'SoftwareApplication',
    name: app.name,
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Odoo 19',
    description: app.desc,
    url: contact.odooApps,
    author: { '@id': `${site.url}/#person` },
  })),
};

/** WebSite schema — helps "Dhiren Narola" brand queries resolve to this site. */
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  name: `${site.name} — Odoo Architect & AI Automation Engineer`,
  alternateName: ['Dhiren Narola', 'dhirennarola.com'],
  url: site.url,
  description: site.tagline,
  inLanguage: 'en',
  publisher: { '@id': `${site.url}/#person` },
};

const allSchemas = [personSchema, websiteSchema, ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={allKeywords} />
    <link rel="canonical" href={canonical} />
    <meta name="author" content={site.name} />
    <meta name="creator" content={site.name} />
    <meta name="publisher" content={site.name} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={`${site.name} — ${site.title}`} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.title}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a1a33" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {site.gaMeasurementId && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${site.gaMeasurementId}`}
        />
        <script
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${site.gaMeasurementId}',{anonymize_ip:true});`}
        />
        {/* Funnel & conversion tracking — captures the journey Enhanced
            Measurement can't: booking intent, actual Calendly bookings
            (postMessage from the embedded iframe), contact channels,
            outbound clicks, PDF downloads, and scroll depth. */}
        <script
          is:inline
          set:html={`(function(){
  function track(n,p){ if(typeof window.gtag==='function'){ window.gtag('event', n, p||{}); } }
  window.__track = track;
  document.addEventListener('click', function(e){
    var el = e.target && e.target.closest ? e.target.closest('a,button') : null;
    if(!el) return;
    var href = (el.getAttribute && el.getAttribute('href')) || '';
    var txt = ((el.textContent||'').replace(/\\s+/g,' ').trim()).slice(0,60);
    if(/^mailto:/i.test(href)){ track('contact_click',{method:'email',link_text:txt,page:location.pathname}); return; }
    if(/^tel:/i.test(href)){ track('contact_click',{method:'phone',link_text:txt,page:location.pathname}); return; }
    if(/wa\\.me|api\\.whatsapp/i.test(href)){ track('contact_click',{method:'whatsapp',link_text:txt,page:location.pathname}); return; }
    if(/\\.pdf($|\\?)/i.test(href)){ track('file_download',{file_name:(href.split('/').pop()||'resume.pdf'),link_text:txt,page:location.pathname}); return; }
    if(/calendly\\.com/i.test(href) || /\\/contact\\/?($|#|\\?)/.test(href) || (el.dataset&&el.dataset.cta==='book') || /book (a|the) (call|discovery|meeting)/i.test(txt)){ track('book_call_click',{link_text:txt,page:location.pathname}); return; }
    if(/linkedin\\.com/i.test(href)){ track('outbound_click',{destination:'linkedin',page:location.pathname}); return; }
    if(/github\\.com/i.test(href)){ track('outbound_click',{destination:'github',page:location.pathname}); return; }
    if(/apps\\.odoo\\.com/i.test(href)){ track('outbound_click',{destination:'odoo_app_store',page:location.pathname}); return; }
  }, true);
  window.addEventListener('message', function(e){
    var d = e && e.data;
    if(d && typeof d.event==='string' && d.event.indexOf('calendly.')===0){
      if(d.event==='calendly.event_scheduled'){ track('meeting_booked',{method:'calendly',page:location.pathname}); }
    }
  });
  var marks=[25,50,75,100], hit={}, pending=false;
  function measure(){ pending=false; var sh=document.documentElement.scrollHeight-window.innerHeight; if(sh<=0) return; var pct=(window.scrollY/sh)*100; for(var i=0;i<marks.length;i++){ var m=marks[i]; if(!hit[m]&&pct>=m){ hit[m]=1; track('scroll_depth',{percent:m,page:location.pathname}); } } }
  window.addEventListener('scroll', function(){ if(!pending){ pending=true; setTimeout(measure,400); } }, {passive:true});
})();`}
        />
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav light={headerLight} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />

    <script>
      // All motion: IntersectionObserver + transform/opacity only. No scroll jank.
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      /* Reveal + stagger + section-head underline */
      const revealEls = document.querySelectorAll('.reveal, [data-stagger]');
      if (reduced) {
        revealEls.forEach((el) => el.classList.add('visible', 'settled'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
                // entrance (600ms) + max stagger delay (490ms) → then release
                // the transition back to hover effects
                setTimeout(() => e.target.classList.add('settled'), 1150);
                io.unobserve(e.target);
              }
            }
          },
          // Tiny threshold + generous margins: the entrance starts just
          // before the element scrolls in (from either direction), so fast
          // scrolling never shows blank gaps, and very tall blocks still
          // trigger reliably.
          { threshold: 0.03, rootMargin: '30% 0px 12% 0px' }
        );
        revealEls.forEach((el) => {
          // Anything already on screen at load (or above it after an anchor
          // jump) shows immediately — no entrance for content you're
          // already looking at.
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight * 0.85 && r.bottom > 0) {
            el.classList.add('visible');
            setTimeout(() => el.classList.add('settled'), 1150);
          } else {
            io.observe(el);
          }
        });
      }

      /* Animated counters */
      const animateCount = (el: HTMLElement) => {
        const target = parseFloat(el.dataset.count || '0');
        const suffix = el.dataset.suffix || '';
        const t0 = performance.now();
        const dur = 900;
        const step = (t: number) => {
          const p = Math.min((t - t0) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(target * eased).toLocaleString('en-US') + suffix;
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };
      const counters = document.querySelectorAll<HTMLElement>('[data-count]');
      if (reduced) {
        counters.forEach((el) => {
          el.textContent =
            parseFloat(el.dataset.count || '0').toLocaleString('en-US') + (el.dataset.suffix || '');
        });
      } else {
        const cio = new IntersectionObserver(
          (entries) =>
            entries.forEach((e) => {
              if (e.isIntersecting) {
                animateCount(e.target as HTMLElement);
                cio.unobserve(e.target);
              }
            }),
          { threshold: 0.6 }
        );
        counters.forEach((el) => cio.observe(el));
      }

      /* Rotating skill line (fixed height — zero layout shift) */
      document.querySelectorAll('.rotator').forEach((rot) => {
        const items = [...rot.querySelectorAll('span')];
        if (items.length < 2) return;
        let i = 0;
        items[0].classList.add('on');
        if (reduced) return;
        setInterval(() => {
          items[i].classList.remove('on');
          items[i].classList.add('off');
          const prev = i;
          i = (i + 1) % items.length;
          items[i].classList.remove('off');
          items[i].classList.add('on');
          setTimeout(() => items[prev].classList.remove('off'), 500);
        }, 3200);
      });

      /* Tabs (industry expertise) */
      document.querySelectorAll('[role="tablist"]').forEach((list) => {
        const tabs = [...list.querySelectorAll<HTMLButtonElement>('.tab')];
        tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            tabs.forEach((t) => t.setAttribute('aria-selected', 'false'));
            tab.setAttribute('aria-selected', 'true');
            const scope = list.closest('section') || document;
            scope.querySelectorAll('.tabpanel').forEach((p) => p.classList.remove('active'));
            scope
              .querySelector('#' + tab.getAttribute('aria-controls'))
              ?.classList.add('active');
          });
        });
      });
    </script>
  </body>
</html>
